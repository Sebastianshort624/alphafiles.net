<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your Vacation Options — Mr. & Mrs. Johnson</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1B2A4A;
    --gold: #C8960C;
    --ice: #EAF0F8;
    --white: #FFFFFF;
    --light-gray: #F5F7FA;
    --text: #1a1a2e;
    --green: #2E7D32;
    --green-light: #E8F5E9;
    --red: #C62828;
    --red-light: #FFEBEE;
    --gold-light: #FFF8E1;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Source Sans 3', sans-serif;
    background: var(--light-gray);
    color: var(--text);
    font-size: 18px;
  }

  /* PAGE NAV */
  .page-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 32px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .page-nav .logo {
    font-family: 'Playfair Display', serif;
    color: var(--gold);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .nav-tabs {
    display: flex;
    gap: 8px;
  }

  .nav-tab {
    background: transparent;
    border: 2px solid rgba(200,150,12,0.4);
    color: rgba(255,255,255,0.7);
    padding: 8px 20px;
    border-radius: 6px;
    cursor: pointer;
    font-family: 'Source Sans 3', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.3s;
  }

  .nav-tab.active, .nav-tab:hover {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--navy);
  }

  /* PAGES */
  .page {
    display: none;
    padding-top: 64px;
    min-height: 100vh;
    animation: fadeIn 0.4s ease;
  }

  .page.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* HERO BANNER */
  .hero {
    background: linear-gradient(135deg, var(--navy) 0%, #2c4a7a 100%);
    color: white;
    padding: 48px 40px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(200,150,12,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }

  .hero-tag {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 16px;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .hero h1 span { color: var(--gold); }

  .hero p {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* MAIN CONTENT */
  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 36px 24px 60px;
  }

  /* SECTION HEADERS */
  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.7rem;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .section-sub {
    font-size: 1rem;
    color: #555;
    margin-bottom: 28px;
    line-height: 1.6;
  }

  /* BIG TRUTH BOX */
  .truth-box {
    background: var(--navy);
    color: white;
    border-radius: 14px;
    padding: 32px 36px;
    margin-bottom: 36px;
    display: flex;
    align-items: center;
    gap: 28px;
    border-left: 6px solid var(--gold);
  }

  .truth-icon {
    font-size: 3rem;
    flex-shrink: 0;
  }

  .truth-box h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .truth-box p {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
  }

  /* RATE CARDS */
  .rate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 12px;
  }

  .rate-card {
    background: white;
    border-radius: 14px;
    padding: 28px 24px;
    box-shadow: 0 3px 16px rgba(0,0,0,0.07);
    border-top: 5px solid var(--green);
    text-align: center;
    position: relative;
  }

  .rate-card .season-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 6px;
  }

  .rate-card .rate-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--navy);
    margin-bottom: 16px;
  }

  .rate-card .per-night {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--navy);
    line-height: 1;
  }

  .rate-card .per-night span {
    font-size: 1rem;
    font-weight: 400;
    color: #777;
  }

  .rate-card .total-2wk {
    margin-top: 12px;
    background: var(--ice);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 1rem;
    color: var(--navy);
  }

  .rate-card .total-2wk strong {
    font-size: 1.2rem;
    color: var(--navy);
  }

  .rate-card .savings-line {
    margin-top: 14px;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--green);
  }

  .footnote {
    font-size: 0.85rem;
    color: #888;
    font-style: italic;
    text-align: center;
    margin-bottom: 36px;
    padding: 10px 0;
    border-top: 1px solid #e0e0e0;
  }

  /* PROOF LINKS */
  .proof-section {
    background: white;
    border-radius: 14px;
    padding: 28px 28px;
    box-shadow: 0 3px 16px rgba(0,0,0,0.07);
    margin-bottom: 36px;
  }

  .proof-section h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--navy);
    margin-bottom: 6px;
  }

  .proof-section .proof-sub {
    font-size: 0.95rem;
    color: #666;
    margin-bottom: 20px;
  }

  .link-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .booking-link {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--ice);
    border: 1.5px solid #c8d8ec;
    border-radius: 10px;
    padding: 14px 16px;
    text-decoration: none;
    color: var(--navy);
    transition: all 0.25s;
    font-weight: 600;
    font-size: 0.98rem;
  }

  .booking-link:hover {
    background: var(--navy);
    color: white;
    border-color: var(--navy);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(27,42,74,0.2);
  }

  .booking-link .link-icon { font-size: 1.4rem; flex-shrink: 0; }

  .booking-link .link-info small {
    display: block;
    font-weight: 400;
    font-size: 0.82rem;
    color: #666;
    margin-top: 1px;
  }

  .booking-link:hover .link-info small { color: rgba(255,255,255,0.7); }

  /* SAVINGS SUMMARY */
  .savings-summary {
    background: linear-gradient(135deg, var(--green) 0%, #388E3C 100%);
    color: white;
    border-radius: 14px;
    padding: 32px 36px;
    margin-bottom: 36px;
    text-align: center;
  }

  .savings-summary h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    margin-bottom: 20px;
  }

  .savings-row {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .savings-item {
    text-align: center;
  }

  .savings-item .big-num {
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1;
  }

  .savings-item .big-label {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
    margin-top: 4px;
  }

  .savings-divider {
    width: 1px;
    background: rgba(255,255,255,0.3);
    align-self: stretch;
  }

  /* ======= PAGE 2 STYLES ======= */

  .p2-hero {
    background: linear-gradient(135deg, #1a3a1a 0%, #2E5C2E 100%);
  }

  .versus-container {
    display: grid;
    grid-template-columns: 1fr 60px 1fr;
    gap: 0;
    margin-bottom: 36px;
    align-items: stretch;
  }

  .vs-col {
    background: white;
    border-radius: 14px;
    padding: 28px 24px;
    box-shadow: 0 3px 16px rgba(0,0,0,0.07);
  }

  .vs-col.left { border-top: 5px solid var(--red); border-radius: 14px 0 0 14px; }
  .vs-col.right { border-top: 5px solid var(--green); border-radius: 0 14px 14px 0; }

  .vs-middle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--navy);
    color: white;
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    writing-mode: vertical-rl;
    letter-spacing: 3px;
  }

  .vs-col h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid #eee;
  }

  .vs-col.left h3 { color: var(--red); }
  .vs-col.right h3 { color: var(--green); }

  .vs-row {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .vs-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.98rem;
    line-height: 1.5;
  }

  .vs-item .vi-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }

  /* COLLETTE OPTIONS */
  .option-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 36px;
  }

  .option-card {
    background: white;
    border-radius: 14px;
    padding: 28px 24px;
    box-shadow: 0 3px 16px rgba(0,0,0,0.07);
    border-top: 5px solid var(--gold);
  }

  .option-card .opt-badge {
    display: inline-block;
    background: var(--gold-light);
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    margin-bottom: 12px;
    border: 1px solid var(--gold);
  }

  .option-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .option-card p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .dest-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .dest-list li {
    font-size: 0.9rem;
    color: var(--navy);
    padding: 6px 10px;
    background: var(--ice);
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* CLOSE QUOTE */
  .close-quote {
    background: var(--navy);
    border-radius: 14px;
    padding: 36px 40px;
    margin-bottom: 36px;
    position: relative;
    overflow: hidden;
  }

  .close-quote::before {
    content: '"';
    position: absolute;
    top: -20px; left: 20px;
    font-family: 'Playfair Display', serif;
    font-size: 12rem;
    color: rgba(200,150,12,0.1);
    line-height: 1;
  }

  .close-quote p {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    color: white;
    line-height: 1.7;
    position: relative;
  }

  .close-quote p span { color: var(--gold); }

  .close-quote .attribution {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    margin-top: 16px;
    font-style: italic;
    position: relative;
  }

  /* COMPARISON TABLE P2 */
  .comp-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 3px 16px rgba(0,0,0,0.07);
    margin-bottom: 36px;
    font-size: 1rem;
  }

  .comp-table thead tr {
    background: var(--navy);
    color: white;
  }

  .comp-table thead th {
    padding: 16px 20px;
    text-align: left;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.5px;
  }

  .comp-table thead th:first-child { width: 30%; }

  .comp-table tbody tr:nth-child(even) { background: var(--ice); }

  .comp-table tbody td {
    padding: 14px 20px;
    border-bottom: 1px solid #eee;
    vertical-align: top;
    line-height: 1.5;
  }

  .comp-table tbody td:first-child {
    font-weight: 700;
    color: var(--navy);
  }

  .bad { color: var(--red); font-weight: 600; }
  .good { color: var(--green); font-weight: 600; }

  /* COLLETTE PROOF LINK */
  .collette-proof {
    background: white;
    border-radius: 14px;
    padding: 24px 28px;
    box-shadow: 0 3px 16px rgba(0,0,0,0.07);
    margin-bottom: 36px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .collette-proof .cp-icon { font-size: 2.5rem; flex-shrink: 0; }

  .collette-proof h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--navy);
    margin-bottom: 6px;
  }

  .collette-proof p {
    font-size: 0.92rem;
    color: #666;
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .cta-link {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    font-weight: 700;
    font-size: 0.92rem;
    padding: 9px 18px;
    border-radius: 8px;
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: all 0.2s;
  }

  .cta-link:hover { background: var(--navy); color: var(--gold); }

  /* FOOTER */
  .page-footer {
    background: var(--navy);
    color: rgba(255,255,255,0.6);
    text-align: center;
    padding: 20px;
    font-size: 0.85rem;
  }

  .page-footer strong { color: var(--gold); }

  @media (max-width: 680px) {
    .rate-grid, .option-grid, .link-grid { grid-template-columns: 1fr; }
    .versus-container { grid-template-columns: 1fr; }
    .vs-middle { display: none; }
    .vs-col.left, .vs-col.right { border-radius: 14px; }
    .savings-row { flex-direction: column; align-items: center; }
    .savings-divider { width: 60px; height: 1px; }
    .truth-box { flex-direction: column; text-align: center; }
    .hero h1 { font-size: 1.6rem; }
  }
</style>
</head>
