    });
    calc();
  }

  function fmtES(n){
    return '$ '+Math.round(n).toLocaleString('es-ES');
  }
  function fmtDate(d){
    return d.toLocaleDateString('es-ES',{day:'numeric',month:'long',year:'numeric'});
  }
  function monthlyPayment(principal, months, apr){
    const r = apr / 12;
    if(r===0) return principal / months;
    return principal * r / (1 - Math.pow(1+r, -months));
  }

  function calc(){
    const fee      = parseFloat(document.getElementById('serviceFee').value) || 0;
    const discRaw  = parseFloat(document.getElementById('discount').value)   || 0;
    const discAmt  = discountMode==='$' ? discRaw : fee * discRaw / 100;
    const yourPrice = Math.max(0, fee - discAmt);
    const payFull   = Math.max(0, yourPrice - CASH_DISC);

    // Dates
