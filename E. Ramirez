<script>
  let discountMode = '$';
  let currentTerm  = 60;
  const CASH_DISC  = 500;
  const APR        = 0.2099; // ~21% APR → ~$177/mo on $6600 over 60 mo

  function setMode(m){
    discountMode = m;
    document.getElementById('btnDollar').classList.toggle('active', m==='$');
    document.getElementById('btnPct').classList.toggle('active', m==='%');
    document.getElementById('discPrefix').textContent = m==='$' ? '$' : '%';
    calc();
  }

  function setTerm(t){
    currentTerm = t;
    document.querySelectorAll('.tab-btn').forEach((b,i)=>{
