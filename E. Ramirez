    const firstPay = new Date(today); firstPay.setDate(firstPay.getDate()+30);
    const payoff90 = new Date(firstPay); payoff90.setDate(payoff90.getDate()+90);

    // Summary
    document.getElementById('sumOrig').textContent     = fmtES(fee).replace('$ ','$');
    document.getElementById('sumDiscount').textContent = '-'+fmtES(discAmt).replace('$ ','$');
    document.getElementById('sumMid').textContent      = fmtES(yourPrice).replace('$ ','$');
    document.getElementById('sumPrice').textContent    = fmtES(yourPrice).replace('$ ','$');

    // Pay full
    document.getElementById('pfOrig').textContent  = fmtES(yourPrice).replace('$ ','$');
    document.getElementById('pfPrice').textContent = fmtES(payFull).replace('$ ','$');
    document.getElementById('pfDate90').textContent = fmtDate(payoff90);

    // Financing
    const mo  = monthlyPayment(yourPrice, currentTerm, APR);
    const tot = mo * currentTerm;
    document.getElementById('finMonthly').textContent  = fmtES(mo);
    document.getElementById('finTotal').textContent    = fmtES(tot);
    document.getElementById('finFirstDate').textContent= fmtDate(firstPay);

    // Notes dates
    document.getElementById('noteDate1').textContent = fmtDate(firstPay);
    document.getElementById('noteDate2').textContent = fmtDate(payoff90);
  }

  calc();
