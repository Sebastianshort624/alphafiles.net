<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ATC Quote Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Barlow+Condensed:wght@400;500;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   TOOL UI
═══════════════════════════════════════════ */
:root{--N:#1B2A4A;--G:#C8960C;--G2:#d4a821;--pale:#EAF0F8;--bd:#d0d8e8;--off:#f4f5f8;--mu:#7a859a;--tx2:#3d4d63}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Barlow',sans-serif;background:#dce4f0;height:100vh;display:flex;flex-direction:column;overflow:hidden}

/* Header */
.tool-hdr{background:var(--N);padding:10px 20px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:3px solid var(--G)}
.hdr-left .logo{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:3.5px;text-transform:uppercase;color:var(--G)}
.hdr-left .title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:#fff}
.hdr-btns{display:flex;gap:8px}
.btn{border:none;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:8px 16px;cursor:pointer;transition:all .15s}
.btn-gold{background:var(--G);color:var(--N)}
.btn-gold:hover{background:var(--G2)}
.btn-outline{background:transparent;color:rgba(255,255,255,.6);border:1.5px solid rgba(255,255,255,.2)}
.btn-outline:hover{color:#fff;border-color:rgba(255,255,255,.5)}

/* Layout */
.tool-body{display:flex;flex:1;overflow:hidden}

/* Input Panel */
.inp{width:330px;flex-shrink:0;background:#fff;border-right:1.5px solid var(--bd);overflow-y:auto;display:flex;flex-direction:column}
.inp-sec{border-bottom:1px solid var(--bd)}
.inp-hdr{background:var(--N);padding:7px 16px}
.inp-hdr span{font-family:'Barlow Condensed',sans-serif;font-size:9.5px;letter-spacing:3px;text-transform:uppercase;color:var(--G);font-weight:700}
.inp-fields{padding:12px 14px;display:flex;flex-direction:column;gap:9px}
.fg{display:flex;flex-direction:column;gap:3px}
.fg.r2{flex-direction:row;gap:7px}
.fg.r2>*{flex:1}
label{font-family:'Barlow Condensed',sans-serif;font-size:8.5px;letter-spacing:2.5px;text-transform:uppercase;color:var(--mu);font-weight:700}
input[type=text],input[type=number],input[type=email],input[type=tel]{width:100%;background:var(--off);border:1.5px solid var(--bd);border-radius:4px;padding:6px 9px;font-size:13px;font-family:'Barlow',sans-serif;color:var(--N);outline:none;transition:border-color .15s}
input:focus{border-color:var(--N)}

/* Chips */
.chips{display:flex;gap:5px;margin-top:3px}
.chip{flex:1;background:var(--pale);border-radius:4px;padding:5px 8px;text-align:center}
.chip .cl{font-family:'Barlow Condensed',sans-serif;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--mu);display:block;margin-bottom:1px}
.chip .cv{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:700;color:var(--N);line-height:1}
.chip.wide{flex:none;width:100%}
.chip.red .cv{color:#b07e00}
.chip.grn .cv{color:#27ae60}

/* Term buttons */
.term-row{display:flex;gap:4px}
.tb{flex:1;padding:6px 0;border:1.5px solid var(--bd);background:var(--off);color:var(--mu);font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;cursor:pointer;border-radius:4px;transition:all .15s}
.tb.on{background:var(--N);color:var(--G);border-color:var(--N)}

/* Preview Panel */
.prev{flex:1;overflow-y:auto;background:#dce4f0;padding:20px}

/* ═══════════════════════════════════════════
   QUOTE STYLES (live preview)
═══════════════════════════════════════════ */
.qw{max-width:680px;margin:0 auto;background:#fff;border-top:5px solid #C8960C;box-shadow:0 4px 32px rgba(27,42,74,.10);font-family:'Barlow',sans-serif;color:#2D2D2D}
.qw .qhdr{background:#1B2A4A;padding:36px 40px 28px;text-align:center}
.qw .qhdr .qlogo{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#C8960C;margin-bottom:6px}
.qw .qhdr h1{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:600;color:#fff;letter-spacing:.5px;line-height:1.2}
.qw .qhdr .qsub{font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:rgba(200,150,12,.75);margin-top:8px}
.qbody{padding:36px 40px}
.qgreet{font-size:15.5px;line-height:1.75;color:#2D2D2D;margin-bottom:30px}
.qgreet strong{color:#1B2A4A}
.qsl{font-family:'Barlow Condensed',sans-serif;font-size:10.5px;letter-spacing:3.5px;text-transform:uppercase;color:#C8960C;margin-bottom:12px}
.qcrow{display:flex;gap:14px;margin-bottom:14px;flex-wrap:wrap}
.qcard{flex:1;min-width:130px;background:#EAF0F8;border-left:3px solid #1B2A4A;padding:16px 18px}
.qcard.alt{border-left-color:#C8960C}
.qcard .qclbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#1B2A4A;opacity:.65;margin-bottom:6px}
.qcard .qcnum{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:700;color:#1B2A4A;line-height:1}
.qcard.alt .qcnum{color:#b07e00}
.qcard .qcsub{font-size:11px;color:#555;margin-top:4px}
.qtbar{background:#1B2A4A;padding:16px 22px;display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:10px}
.qtgrp{text-align:center}
.qtlbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.55)}
.qtval{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;color:#fff;line-height:1}
.qtnote{font-size:9.5px;color:rgba(255,255,255,.4);margin-top:2px;font-family:'Barlow Condensed',sans-serif;letter-spacing:2px;text-transform:uppercase}
.qtdiv{width:1px;height:38px;background:rgba(255,255,255,.15)}
.qctable{width:100%;border-collapse:collapse;margin-bottom:8px}
.qctable thead tr{background:#1B2A4A}
.qctable thead th{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);padding:9px 14px;text-align:left;font-weight:500}
.qctable thead th:last-child{text-align:right}
.qctable tbody tr{border-bottom:1px solid #e8edf4}
.qctable tbody tr:last-child{border-bottom:none}
.qctable tbody tr:nth-child(even){background:#f7f9fc}
.qctable td{padding:11px 14px;font-size:14px}
.qctable td.ylbl{font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;color:#1B2A4A;font-weight:600}
.qctable td.yamt{text-align:right;font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:#1B2A4A}
.qctable tbody tr:last-child td.yamt{color:#C8960C}
.qgnote{font-size:11px;color:#888;margin-top:8px;font-style:italic;margin-bottom:28px}
.qdiv{height:1px;background:linear-gradient(to right,#C8960C,transparent);margin:26px 0}
.qfbox{background:#1B2A4A;padding:22px 26px;margin-bottom:14px;position:relative;overflow:hidden}
.qfbox::before{content:'';position:absolute;top:0;right:0;width:80px;height:80px;background:rgba(200,150,12,.07);border-radius:50%;transform:translate(20px,-20px)}
.qfbox .qflbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3.5px;text-transform:uppercase;color:#C8960C;margin-bottom:6px}
.qfbox .qfamt{font-family:'Cormorant Garamond',serif;font-size:46px;font-weight:700;color:#fff;line-height:1}
.qfbox .qfsub{font-size:12px;color:rgba(255,255,255,.55);margin-top:6px}
.qsdbox{background:#EAF0F8;border-left:4px solid #C8960C;padding:16px 20px;margin-bottom:12px}
.qsdbox .qsdlbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#C8960C;margin-bottom:3px}
.qsdbox .qsdhl{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#1B2A4A;margin-bottom:3px}
.qsdbox .qsddt{font-size:12.5px;color:#555;line-height:1.6}
.qbvbox{background:#1B2A4A;border-left:4px solid #C8960C;padding:16px 20px;margin-bottom:26px}
.qbvbox .qbvlbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#C8960C;margin-bottom:3px}
.qbvbox .qbvhl{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#fff;margin-bottom:3px}
.qbvbox .qbvdt{font-size:12.5px;color:rgba(255,255,255,.6);line-height:1.6}
.qfgrid{display:flex;gap:12px;margin-bottom:26px;flex-wrap:wrap}
.qfc{flex:1;min-width:130px;border:1.5px solid #dde3ed;padding:15px 16px}
.qfc.feat{border-color:#C8960C;background:#fffdf5}
.qfc .qftag{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#C8960C;margin-bottom:7px}
.qfc .qfamt2{font-family:'Cormorant Garamond',serif;font-size:29px;font-weight:700;color:#1B2A4A;line-height:1}
.qfc .qfnote{font-size:11px;color:#666;margin-top:5px;line-height:1.5}
.qfc .qfbadge{display:inline-block;background:#C8960C;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:3px 8px;margin-top:7px}
.qproc{margin-bottom:26px}
.qsteps{display:flex;flex-direction:column;gap:9px;margin-top:11px}
.qstep{display:flex;align-items:flex-start;gap:13px}
.qsnum{min-width:27px;height:27px;background:#1B2A4A;color:#C8960C;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.qstxt{font-size:13px;color:#2D2D2D;padding-top:5px;line-height:1.5}
.qstxt strong{color:#1B2A4A}
.qexbox{background:#EAF0F8;padding:20px 22px;margin-bottom:26px;border-top:2px solid #1B2A4A}
.qexbox p{font-size:13px;line-height:1.7;color:#2D2D2D}
.qexbox p strong{color:#1B2A4A}
.qpq{border-left:3px solid #C8960C;padding:13px 18px;margin-bottom:26px;font-family:'Cormorant Garamond',serif;font-size:19px;font-style:italic;color:#1B2A4A;line-height:1.5}
.qpq cite{display:block;font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:#C8960C;font-style:normal;margin-top:7px}
.qsig{padding:22px 0 10px;border-top:1px solid #dde3ed;margin-bottom:18px}
.qsigname{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#1B2A4A}
.qsigtitle{font-family:'Barlow Condensed',sans-serif;font-size:10.5px;letter-spacing:2.5px;text-transform:uppercase;color:#C8960C;margin-top:3px}
.qsigct{font-size:12px;color:#555;margin-top:7px;line-height:1.7}
.qsigct a{color:#1B2A4A;text-decoration:none}
.qdisc{font-size:10px;color:#aaa;line-height:1.6;padding:14px 40px 22px;border-top:1px solid #eee;background:#f9fafb}
.qftr{background:#1B2A4A;padding:14px 40px;text-align:center}
.qftr p{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.3)}
</style>
</head>
<body>

<!-- ── HEADER ── -->
<div class="tool-hdr">
  <div class="hdr-left">
    <div class="logo">Alpha Timeshare Consultants</div>
    <div class="title">Quote Generator</div>
  </div>
  <div class="hdr-btns">
    <button class="btn btn-outline" onclick="copyHTML()">Copy HTML</button>
    <button class="btn btn-gold" onclick="openEmail()">⬡ Open as Email</button>
  </div>
</div>

<!-- ── BODY ── -->
<div class="tool-body">

  <!-- ══════ INPUT PANEL ══════ -->
  <div class="inp">

    <!-- CLIENT INFO -->
    <div class="inp-sec">
      <div class="inp-hdr"><span>Client Info</span></div>
      <div class="inp-fields">
        <div class="fg r2">
          <div><label>First Name</label><input type="text" id="fn" value="" placeholder="First" oninput="go()"></div>
          <div><label>Last Name</label><input type="text" id="ln" value="" placeholder="Last" oninput="go()"></div>
        </div>
        <div class="fg r2">
          <div><label>2nd Owner Prefix</label><input type="text" id="p2" placeholder="Mrs." oninput="go()"></div>
          <div><label>2nd Owner Last</label><input type="text" id="l2" placeholder="Last name" oninput="go()"></div>
        </div>
        <div class="fg"><label>Resort (optional)</label><input type="text" id="resort" placeholder="e.g. Marriott Vacation Club" oninput="go()"></div>
        <div class="fg"><label>Email</label><input type="email" id="email" placeholder="client@email.com" oninput="go()"></div>
        <div class="fg"><label>Phone</label><input type="tel" id="phone" placeholder="+1 (000) 000-0000" oninput="go()"></div>
      </div>
    </div>

    <!-- OWNERSHIP -->
    <div class="inp-sec">
      <div class="inp-hdr"><span>Ownership Details</span></div>
      <div class="inp-fields">
        <div class="fg">
          <label>Annual Maintenance Fee ($)</label>
          <input type="number" id="mf" value="900" min="0" oninput="go()">
          <div class="chips">
            <div class="chip"><span class="cl">Monthly</span><span class="cv" id="d_mfmo">$75</span></div>
            <div class="chip"><span class="cl">Annual</span><span class="cv" id="d_mfyr">$900</span></div>
          </div>
        </div>
        <div class="fg">
          <label>Months Behind</label>
          <input type="number" id="beh" value="0" min="0" oninput="go()">
          <div class="chips">
            <div class="chip wide"><span class="cl">Amount Behind</span><span class="cv" id="d_beh">$0</span></div>
          </div>
        </div>
        <div class="fg">
          <label>Monthly Mortgage ($) — 0 if paid off</label>
          <input type="number" id="mtg" value="0" min="0" oninput="go()">
          <div class="chips">
            <div class="chip"><span class="cl">Monthly</span><span class="cv" id="d_mtgmo">$0</span></div>
            <div class="chip"><span class="cl">Annual</span><span class="cv" id="d_mtgyr">$0</span></div>
          </div>
        </div>
        <div class="fg r2">
          <div><label>Growth Rate (%/yr)</label><input type="number" id="gr" value="8" min="0" oninput="go()"></div>
          <div><label>Year Purchased</label><input type="number" id="yr" value="2015" oninput="go()"></div>
        </div>
        <div class="chips">
          <div class="chip"><span class="cl">Total / Month</span><span class="cv" id="d_totmo">$75</span></div>
          <div class="chip"><span class="cl">Total / Year</span><span class="cv" id="d_totyr">$900</span></div>
        </div>
      </div>
    </div>

    <!-- FEE & FINANCING -->
    <div class="inp-sec">
      <div class="inp-hdr"><span>Service Fee &amp; Financing</span></div>
      <div class="inp-fields">
        <div class="fg"><label>Service Fee ($)</label><input type="number" id="fee" value="3500" min="0" oninput="go()"></div>
        <div class="fg">
          <label>PIF Discount ($)</label>
          <input type="number" id="pifd" value="500" min="0" oninput="go()">
          <div class="chips">
            <div class="chip wide"><span class="cl">Pay In Full Total</span><span class="cv" id="d_pif">$3,000</span></div>
          </div>
        </div>
        <div class="fg"><label>Annual Interest Rate (%)</label><input type="number" id="rate" value="20" min="0" oninput="go()"></div>
        <div class="fg">
          <label>Financing Term (months)</label>
          <div class="term-row">
            <button class="tb" id="tb12" onclick="setTerm(12)">12 Mo</button>
            <button class="tb" id="tb24" onclick="setTerm(24)">24 Mo</button>
            <button class="tb" id="tb36" onclick="setTerm(36)">36 Mo</button>
            <button class="tb on" id="tb60" onclick="setTerm(60)">60 Mo</button>
          </div>
          <div class="chips" style="margin-top:5px">
            <div class="chip"><span class="cl">Monthly Payment</span><span class="cv" id="d_pmt">$93</span></div>
            <div class="chip"><span class="cl">vs. Maint Fee</span><span class="cv" id="d_diff">—</span></div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /inp -->

  <!-- ══════ PREVIEW PANEL ══════ -->
  <div class="prev" id="prev"></div>

</div><!-- /tool-body -->

<script>
var _term = 60;

/* ── Utilities ── */
function v(id){ return document.getElementById(id); }
function fmtI(n){ return Math.round(n).toLocaleString('en-US'); }
function fmtD(n){ return Number(n.toFixed(2)).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}); }

function setTerm(t){
  _term=t;
  [12,24,36,60].forEach(function(n){ v('tb'+n).className='tb'+(n===t?' on':''); });
  go();
}

function payment(principal, annualRate, months){
  if(!principal || !months) return 0;
  if(!annualRate) return principal/months;
  var r=annualRate/100/12;
  return principal*(r*Math.pow(1+r,months))/(Math.pow(1+r,months)-1);
}

function proj(annualFee, mtgMo, years, growthRate, purchaseYear){
  var payoff=purchaseYear+10;
  var cur=new Date().getFullYear();
  var total=0;
  for(var i=0;i<years;i++){
    var y=cur+i;
    total+=annualFee*Math.pow(1+growthRate/100,i);
    if(y<payoff && mtgMo>0) total+=mtgMo*12;
  }
  return total;
}

/* ── Read inputs ── */
function vals(){
  return {
    fn:   (v('fn').value||'').trim(),
    ln:   (v('ln').value||'').trim(),
    p2:   (v('p2').value||'').trim(),
    l2:   (v('l2').value||'').trim(),
    resort:(v('resort').value||'').trim(),
    email:(v('email').value||'').trim(),
    phone:(v('phone').value||'').trim(),
    mf:   Math.max(0,+v('mf').value||0),
    beh:  Math.max(0,+v('beh').value||0),
    mtg:  Math.max(0,+v('mtg').value||0),
    gr:   Math.max(0,+v('gr').value||8),
    yr:   +v('yr').value||2015,
    fee:  Math.max(0,+v('fee').value||0),
    pifd: Math.max(0,+v('pifd').value||500),
    rate: Math.max(0,+v('rate').value||20)
  };
}

/* ── Main render ── */
function go(){
  var d=vals();
  var mfMo=d.mf/12, behind=mfMo*d.beh, totMo=mfMo+d.mtg, totYr=d.mf+d.mtg*12;
  var pif=Math.max(0,d.fee-d.pifd), pmt=payment(d.fee,d.rate,_term);
  var diff=mfMo-pmt;
  var p3=proj(d.mf,d.mtg,3,d.gr,d.yr), p5=proj(d.mf,d.mtg,5,d.gr,d.yr);
  var p7=proj(d.mf,d.mtg,7,d.gr,d.yr), p10=proj(d.mf,d.mtg,10,d.gr,d.yr);
  var p20=proj(d.mf,d.mtg,20,d.gr,d.yr), p30=proj(d.mf,d.mtg,30,d.gr,d.yr);

  /* update panel chips */
  v('d_mfmo').textContent='$'+fmtI(mfMo);
  v('d_mfyr').textContent='$'+fmtI(d.mf);
  v('d_beh').textContent='$'+fmtI(behind);
  v('d_mtgmo').textContent='$'+fmtI(d.mtg);
  v('d_mtgyr').textContent='$'+fmtI(d.mtg*12);
  v('d_totmo').textContent='$'+fmtI(totMo);
  v('d_totyr').textContent='$'+fmtI(totYr);
  v('d_pif').textContent='$'+fmtI(pif);
  v('d_pmt').textContent='$'+Math.round(pmt);
  var de=v('d_diff');
  if(diff>=0){ de.textContent='+$'+Math.round(diff)+'/mo saved'; de.parentElement.className='chip grn'; }
  else { de.textContent='$'+Math.round(Math.abs(diff))+'/mo more'; de.parentElement.className='chip red'; }

  /* salutation */
  var fn=d.fn||'Client', ln=d.ln||'';
  var sal='Mr. '+ln;
  if(d.p2&&d.l2) sal+=' &amp; '+d.p2+' '+d.l2;

  /* conditional card/bar sections */
  var behCard=behind>0?'<div class="qcard alt"><div class="qclbl">Currently Behind</div><div class="qcnum">$'+fmtI(behind)+'</div><div class="qcsub">'+d.beh+' months past due</div></div>':'';
  var mtgCard=d.mtg>0?
    '<div class="qcard"><div class="qclbl">Monthly Mortgage</div><div class="qcnum">$'+fmtI(d.mtg)+'</div><div class="qcsub">$'+fmtI(d.mtg*12)+' annually</div></div>':
    '<div class="qcard"><div class="qclbl">Mortgage Balance</div><div class="qcnum">$0</div><div class="qcsub">Paid in full</div></div>';
  var behBar=behind>0?'<div class="qtdiv"></div><div class="qtgrp"><div class="qtlbl">Amount Behind</div><div class="qtval">$'+fmtI(behind)+'</div><div class="qtnote">'+d.beh+' Months</div></div>':'';

