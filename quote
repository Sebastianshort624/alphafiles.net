<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ATC Quote Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Barlow+Condensed:wght@400;500;600;700&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════ RESET + ROOT ═══════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --N:#1B2A4A;--G:#C8960C;--G2:#d4a821;
  --pale:#EAF0F8;--bd:#c4cfe0;--off:#edf1f7;
  --tx:#1B2A4A;--mu:#7a859a
}
body{font-family:'Barlow',sans-serif;background:#dce4f0;height:100vh;display:flex;flex-direction:column;overflow:hidden}

/* ═══════════════════ TOOL HEADER ═══════════════════ */
.tool-hdr{background:var(--N);padding:11px 22px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:3px solid var(--G)}
.hdr-l .lbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3.5px;text-transform:uppercase;color:var(--G);font-weight:700}
.hdr-l .ttl{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:700;color:#fff;line-height:1}
.hdr-btns{display:flex;gap:8px}
.btn{border:none;font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:9px 18px;cursor:pointer;transition:all .15s}
.btn-gold{background:var(--G);color:var(--N)}
.btn-gold:hover{background:var(--G2)}
.btn-out{background:transparent;color:rgba(255,255,255,.65);border:1.5px solid rgba(255,255,255,.25)}
.btn-out:hover{color:#fff;border-color:rgba(255,255,255,.55)}

/* ═══════════════════ LAYOUT ═══════════════════ */
.tool-body{display:flex;flex:1;overflow:hidden}

/* ═══════════════════ INPUT PANEL ═══════════════════ */
.inp{width:320px;flex-shrink:0;background:#fff;border-right:2px solid var(--bd);overflow-y:auto;display:flex;flex-direction:column}
.isec{border-bottom:2px solid var(--bd)}
.isec-hdr{background:var(--N);padding:9px 18px}
.isec-hdr span{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--G);font-weight:700}
.ifields{padding:14px 16px;display:flex;flex-direction:column;gap:12px}
.fg{display:flex;flex-direction:column;gap:5px}
.fg.r2{flex-direction:row;gap:10px}
.fg.r2>*{flex:1}

/* Labels — dark, bold, readable */
label{
  font-family:'Barlow Condensed',sans-serif;
  font-size:11px;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--N);
  font-weight:700;
  display:block;
}

/* Inputs */
input[type=text],input[type=number]{
  width:100%;
  background:var(--off);
  border:2px solid var(--bd);
  border-radius:5px;
  padding:9px 12px;
  font-size:15px;
  font-family:'Barlow',sans-serif;
  font-weight:500;
  color:var(--N);
  outline:none;
  transition:border-color .15s;
}
input:focus{border-color:var(--N);background:#fff}

/* Chips */
.chips{display:flex;gap:6px;margin-top:4px}
.chip{
  flex:1;
  background:var(--pale);
  border:1.5px solid #c4d4e8;
  border-radius:5px;
  padding:7px 10px;
  text-align:center;
}
.chip.wide{flex:none;width:100%}
.chip .cl{
  font-family:'Barlow Condensed',sans-serif;
  font-size:9.5px;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--G);
  font-weight:700;
  display:block;
  margin-bottom:2px;
}
.chip .cv{
  font-family:'Cormorant Garamond',serif;
  font-size:20px;
  font-weight:700;
  color:var(--N);
  line-height:1;
}
.chip.red .cv{color:#b07e00}
.chip.grn .cv{color:#1e8449}

/* Term buttons */
.term-row{display:flex;gap:5px}
.tb{
  flex:1;padding:8px 0;
  border:2px solid var(--bd);
  background:var(--off);
  color:var(--N);
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;font-weight:700;
  cursor:pointer;border-radius:5px;
  transition:all .15s;
}
.tb.on{background:var(--N);color:var(--G);border-color:var(--N)}

/* ═══════════════════ PREVIEW PANEL ═══════════════════ */
.prev{flex:1;overflow-y:auto;background:#dce4f0;padding:20px}

/* ═══════════════════ QUOTE STYLES ═══════════════════ */
.qw{max-width:680px;margin:0 auto;background:#fff;border-top:5px solid #C8960C;box-shadow:0 4px 32px rgba(27,42,74,.12);font-family:'Barlow',sans-serif;color:#2D2D2D}
/* Header */
.qhdr{background:#1B2A4A;padding:36px 40px 28px;text-align:center}
.qhdr .qlogo{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#C8960C;margin-bottom:6px}
.qhdr h1{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:600;color:#fff;letter-spacing:.5px;line-height:1.2}
.qhdr .qsub{font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:rgba(200,150,12,.75);margin-top:8px}
/* Body */
.qbody{padding:36px 40px}
.qgreet{font-size:15.5px;line-height:1.75;color:#2D2D2D;margin-bottom:30px}
.qgreet strong{color:#1B2A4A}
/* Section labels — LARGER + BOLDER */
.qsl{
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;
  letter-spacing:3px;
  text-transform:uppercase;
  color:#C8960C;
  font-weight:700;
  margin-bottom:13px;
}
/* Cards */
.qcrow{display:flex;gap:14px;margin-bottom:14px;flex-wrap:wrap}
.qcard{flex:1;min-width:130px;background:#EAF0F8;border-left:3px solid #1B2A4A;padding:16px 18px}
.qcard.alt{border-left-color:#C8960C}
.qcard .qclbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#1B2A4A;opacity:.65;margin-bottom:6px}
.qcard .qcnum{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:700;color:#1B2A4A;line-height:1}
.qcard.alt .qcnum{color:#b07e00}
.qcard .qcsub{font-size:11px;color:#555;margin-top:4px}
/* Total bar */
.qtbar{background:#1B2A4A;padding:16px 22px;display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:10px}
.qtgrp{text-align:center}
.qtlbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.55)}
.qtval{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;color:#fff;line-height:1}
.qtnote{font-size:9.5px;color:rgba(255,255,255,.4);margin-top:2px;font-family:'Barlow Condensed',sans-serif;letter-spacing:2px;text-transform:uppercase}
.qtdiv{width:1px;height:38px;background:rgba(255,255,255,.15)}
/* Cost table */
.qctbl{width:100%;border-collapse:collapse;margin-bottom:8px}
.qctbl thead tr{background:#1B2A4A}
.qctbl thead th{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);padding:9px 14px;text-align:left;font-weight:500}
.qctbl thead th:last-child{text-align:right}
.qctbl tbody tr{border-bottom:1px solid #e8edf4}
.qctbl tbody tr:last-child{border-bottom:none}
.qctbl tbody tr:nth-child(odd){background:#fff}
.qctbl tbody tr:nth-child(even){background:#f7f9fc}
/* Standard rows (3/5/7yr) */
.qctbl td{padding:11px 14px;font-size:14px;color:#2D2D2D}
.qctbl td.ylbl{font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;color:#1B2A4A;font-weight:600}
.qctbl td.yamt{text-align:right;font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:#1B2A4A}
/* Bold rows (10/20/30yr) — SEPARATED with top border */
.qctbl tr.bigrow{border-top:2.5px solid #1B2A4A}
.qctbl tr.bigrow td{padding:13px 14px;background:#EAF0F8}
.qctbl tr.bigrow:nth-child(even) td{background:#e0e9f4}
.qctbl tr.bigrow td.ylbl{font-family:'Barlow Condensed',sans-serif;font-size:14px;letter-spacing:2px;font-weight:700;color:#1B2A4A}
.qctbl tr.bigrow td.yamt{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:700;color:#1B2A4A}
.qctbl tbody tr:last-child td.yamt{color:#C8960C}
/* Growth note */
.qgnote{font-size:11px;color:#888;margin-top:8px;font-style:italic;margin-bottom:28px}
/* Gold divider */
.qdiv{height:1px;background:linear-gradient(to right,#C8960C,transparent);margin:26px 0}
/* Fee box */
.qfbox{background:#1B2A4A;padding:22px 26px;margin-bottom:14px;position:relative;overflow:hidden}
.qfbox::before{content:'';position:absolute;top:0;right:0;width:80px;height:80px;background:rgba(200,150,12,.07);border-radius:50%;transform:translate(20px,-20px)}
.qfbox .qflbl{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3.5px;text-transform:uppercase;color:#C8960C;margin-bottom:6px;font-weight:700}
.qfbox .qfamt{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:700;color:#fff;line-height:1}
.qfbox .qfsub{font-size:12px;color:rgba(255,255,255,.55);margin-top:6px}
/* Same day */
.qsdbox{background:#EAF0F8;border-left:4px solid #C8960C;padding:16px 20px;margin-bottom:12px}
.qsdbox .qsdlbl{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#C8960C;margin-bottom:3px;font-weight:700}
.qsdbox .qsdhl{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#1B2A4A;margin-bottom:3px}
.qsdbox .qsddt{font-size:12.5px;color:#555;line-height:1.6}
/* Best value */
.qbvbox{background:#1B2A4A;border-left:4px solid #C8960C;padding:16px 20px;margin-bottom:26px}
.qbvbox .qbvlbl{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#C8960C;margin-bottom:3px;font-weight:700}
.qbvbox .qbvhl{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#fff;margin-bottom:3px}
.qbvbox .qbvdt{font-size:12.5px;color:rgba(255,255,255,.6);line-height:1.6}
/* Fin grid */
.qfgrid{display:flex;gap:12px;margin-bottom:26px;flex-wrap:wrap}
.qfc{flex:1;min-width:130px;border:1.5px solid #dde3ed;padding:15px 16px}
.qfc.feat{border-color:#C8960C;background:#fffdf5}
.qfc .qftag{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:#C8960C;margin-bottom:7px;font-weight:700}
.qfc .qfamt2{font-family:'Cormorant Garamond',serif;font-size:29px;font-weight:700;color:#1B2A4A;line-height:1}
.qfc .qfnote{font-size:11px;color:#666;margin-top:5px;line-height:1.5}
.qfc .qfbadge{display:inline-block;background:#C8960C;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:3px 9px;margin-top:7px;font-weight:700}
/* Alpha process */
.qproc{margin-bottom:26px}
.qsteps{display:flex;flex-direction:column;gap:9px;margin-top:12px}
.qstep{display:flex;align-items:flex-start;gap:13px}
.qsnum{min-width:28px;height:28px;background:#1B2A4A;color:#C8960C;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.qstxt{font-size:13.5px;color:#2D2D2D;padding-top:4px;line-height:1.5}
.qstxt strong{color:#1B2A4A}
/* Exit guarantee */
.qexbox{background:#EAF0F8;padding:20px 22px;margin-bottom:26px;border-top:2px solid #1B2A4A}
.qexbox p{font-size:13.5px;line-height:1.7;color:#2D2D2D}
.qexbox p strong{color:#1B2A4A}
/* Pull quote */
.qpq{border-left:3px solid #C8960C;padding:13px 18px;margin-bottom:26px;font-family:'Cormorant Garamond',serif;font-size:19px;font-style:italic;color:#1B2A4A;line-height:1.5}
.qpq cite{display:block;font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#C8960C;font-style:normal;margin-top:7px;font-weight:700}
/* Signature */
.qsig{padding:22px 0 10px;border-top:1px solid #dde3ed;margin-bottom:18px}
.qsigname{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:#1B2A4A}
.qsigtitle{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#C8960C;margin-top:3px;font-weight:700}
.qsigct{font-size:12.5px;color:#555;margin-top:8px;line-height:1.7}
.qsigct a{color:#1B2A4A;text-decoration:none}
/* Footer */
.qdisc{font-size:10px;color:#aaa;line-height:1.6;padding:14px 40px 22px;border-top:1px solid #eee;background:#f9fafb}
.qftr{background:#1B2A4A;padding:14px 40px;text-align:center}
.qftr p{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.3)}
</style>
</head>
<body>

<!-- ══════ HEADER ══════ -->
<div class="tool-hdr">
  <div class="hdr-l">
    <div class="lbl">Alpha Timeshare Consultants</div>
    <div class="ttl">Quote Generator</div>
  </div>
  <div class="hdr-btns">
    <button class="btn btn-out" onclick="copyHTML()">Copy HTML</button>
    <button class="btn btn-gold" onclick="openEmail()">⬡ Open as Email</button>
  </div>
</div>

<!-- ══════ BODY ══════ -->
<div class="tool-body">

  <!-- ════ INPUT PANEL ════ -->
  <div class="inp">

    <!-- CLIENT INFO -->
    <div class="isec">
      <div class="isec-hdr"><span>Client Info</span></div>
      <div class="ifields">
        <div class="fg">
          <label>Owner Full Name</label>
          <input type="text" id="owner" placeholder="e.g. Michael Haywood" oninput="go()">
        </div>
        <div class="fg">
          <label>Co-Owner Full Name</label>
          <input type="text" id="coowner" placeholder="e.g. Sarah Haywood (optional)" oninput="go()">
        </div>
        <div class="fg">
          <label>Resort</label>
          <input type="text" id="resort" placeholder="e.g. Marriott Vacation Club" oninput="go()">
        </div>
      </div>
    </div>

    <!-- OWNERSHIP DETAILS -->
    <div class="isec">
      <div class="isec-hdr"><span>Ownership Details</span></div>
      <div class="ifields">
        <div class="fg">
          <label>Annual Maintenance Fee ($)</label>
          <input type="number" id="mf" value="900" min="0" oninput="go()">
          <div class="chips">
            <div class="chip"><span class="cl">Monthly</span><span class="cv" id="d_mfmo">$75</span></div>
            <div class="chip"><span class="cl">Annual</span><span class="cv" id="d_mfyr">$900</span></div>
          </div>
        </div>
        <div class="fg">
          <label>Months Behind</label>
          <input type="number" id="beh" value="0" min="0" oninput="go()">
          <div class="chips">
            <div class="chip wide"><span class="cl">Amount Behind</span><span class="cv" id="d_beh">$0</span></div>
          </div>
        </div>
        <div class="fg">
          <label>Monthly Mortgage ($) — 0 if paid off</label>
          <input type="number" id="mtg" value="0" min="0" oninput="go()">
          <div class="chips">
            <div class="chip"><span class="cl">Monthly</span><span class="cv" id="d_mtgmo">$0</span></div>
            <div class="chip"><span class="cl">Annual</span><span class="cv" id="d_mtgyr">$0</span></div>
          </div>
        </div>
        <div class="fg r2">
          <div>
            <label>Growth Rate (%/yr)</label>
            <input type="number" id="gr" value="8" min="0" oninput="go()">
          </div>
          <div>
            <label>Year Purchased</label>
            <input type="number" id="yr" value="2015" oninput="go()">
          </div>
        </div>
        <div class="chips">
          <div class="chip"><span class="cl">Total / Month</span><span class="cv" id="d_totmo">$75</span></div>
          <div class="chip"><span class="cl">Total / Year</span><span class="cv" id="d_totyr">$900</span></div>
        </div>
      </div>
    </div>

    <!-- SERVICE FEE & FINANCING -->
    <div class="isec">
      <div class="isec-hdr"><span>Service Fee &amp; Financing</span></div>
      <div class="ifields">
        <div class="fg">
          <label>Service Fee ($)</label>
          <input type="number" id="fee" value="3500" min="0" oninput="go()">
        </div>
        <div class="fg">
          <label>Annual Interest Rate (%)</label>
          <input type="number" id="rate" value="20" min="0" oninput="go()">
        </div>
        <div class="fg">
          <label>Financing Term (months)</label>
          <div class="term-row">
            <button class="tb" id="tb12" onclick="setTerm(12)">12 Mo</button>
            <button class="tb" id="tb24" onclick="setTerm(24)">24 Mo</button>
            <button class="tb" id="tb36" onclick="setTerm(36)">36 Mo</button>
            <button class="tb on" id="tb60" onclick="setTerm(60)">60 Mo</button>
          </div>
          <div class="chips" style="margin-top:6px">
            <div class="chip"><span class="cl">Monthly Payment</span><span class="cv" id="d_pmt">$93</span></div>
            <div class="chip" id="chip_diff"><span class="cl">vs. Maint Fee</span><span class="cv" id="d_diff">—</span></div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /inp -->

  <!-- ════ PREVIEW PANEL ════ -->
  <div class="prev" id="prev"></div>

</div><!-- /tool-body -->

<script>
var _term = 60;

function el(id){ return document.getElementById(id); }
function fmtI(n){ return Math.round(n).toLocaleString('en-US'); }
function fmtD(n){ return Number(n.toFixed(2)).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}); }

function setTerm(t){
  _term = t;
  [12,24,36,60].forEach(function(n){ el('tb'+n).className='tb'+(n===t?' on':''); });
  go();
}

function calcPayment(principal, annualRate, months){
  if(!principal||!months) return 0;
  if(!annualRate) return principal/months;
  var r = annualRate/100/12;
  return principal*(r*Math.pow(1+r,months))/(Math.pow(1+r,months)-1);
}

function calcProj(annualFee, mtgMo, years, growthRate, purchaseYear){
  var payoff = purchaseYear+10;
  var cur = new Date().getFullYear();
  var total = 0;
  for(var i=0;i<years;i++){
    var y = cur+i;
    total += annualFee * Math.pow(1+growthRate/100, i);
    if(y < payoff && mtgMo>0) total += mtgMo*12;
  }
  return total;
}

function getVals(){
  return {
    owner:  (el('owner').value||'').trim(),
    coowner:(el('coowner').value||'').trim(),
    resort: (el('resort').value||'').trim(),
    mf:     Math.max(0, +el('mf').value||0),
    beh:    Math.max(0, +el('beh').value||0),
    mtg:    Math.max(0, +el('mtg').value||0),
    gr:     Math.max(0, +el('gr').value||8),
    yr:     +el('yr').value||2015,
    fee:    Math.max(0, +el('fee').value||0),
    rate:   Math.max(0, +el('rate').value||20)
  };
}

function go(){
  var d = getVals();
  var mfMo   = d.mf/12;
  var behind = mfMo * d.beh;
  var totMo  = mfMo + d.mtg;
  var totYr  = d.mf + d.mtg*12;
  var pmt    = calcPayment(d.fee, d.rate, _term);
  var diff   = mfMo - pmt;

  var p3  = calcProj(d.mf,d.mtg,3, d.gr,d.yr);
  var p5  = calcProj(d.mf,d.mtg,5, d.gr,d.yr);
  var p7  = calcProj(d.mf,d.mtg,7, d.gr,d.yr);
  var p10 = calcProj(d.mf,d.mtg,10,d.gr,d.yr);
  var p20 = calcProj(d.mf,d.mtg,20,d.gr,d.yr);
  var p30 = calcProj(d.mf,d.mtg,30,d.gr,d.yr);

  /* ── update left panel chips ── */
  el('d_mfmo').textContent  = '$'+fmtI(mfMo);
  el('d_mfyr').textContent  = '$'+fmtI(d.mf);
  el('d_beh').textContent   = '$'+fmtI(behind);
  el('d_mtgmo').textContent = '$'+fmtI(d.mtg);
  el('d_mtgyr').textContent = '$'+fmtI(d.mtg*12);
  el('d_totmo').textContent = '$'+fmtI(totMo);
  el('d_totyr').textContent = '$'+fmtI(totYr);
  el('d_pmt').textContent   = '$'+Math.round(pmt);
  var dc = el('d_diff'), cp = el('chip_diff');
  if(diff>=0){ dc.textContent='+$'+Math.round(diff)+'/mo'; cp.className='chip grn'; }
  else        { dc.textContent='$'+Math.round(Math.abs(diff))+'/mo more'; cp.className='chip red'; }

  /* ── salutation ── */
